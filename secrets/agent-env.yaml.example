# Agent secrets — plaintext template
# Copy this to agent-env.sops.yaml, fill in values, then encrypt:
#   cp agent-env.yaml.example agent-env.sops.yaml
#   $EDITOR agent-env.sops.yaml
#   sops -e -i agent-env.sops.yaml
GITHUB_PAT: "ghp_your_token_here"
VERCEL_TOKEN: "your_vercel_token_here"
OPENAI_API_KEY: "sk-your_key_here"
